<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log in to Wise | Send money abroad</title>
    <link rel="stylesheet" href="css/wise.css">
</head>
<body class="login-page">
    <div class="login-container">
        <div class="login-card">
            <img src="images/wise-logo.png" alt="Wise" class="logo">
            <h1>Log in to your Wise account</h1>
            
            <form id="loginForm" class="auth-form">
                <div class="input-group">
                    <label>Email or phone</label>
                    <input type="text" id="email" placeholder="you@example.com" required>
                </div>
                <div class="input-group">
                    <label>Password</label>
                    <input type="password" id="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn-primary full-width">Log in</button>
            </form>
            
            <div class="divider">or</div>
            
            <button class="btn-google">Continue with Google</button>
            <a href="#" class="forgot-password">Forgot password?</a>
            <div class="auth-footer">
                <p>Don't have an account? <a href="#" class="signup-link">Sign up</a></p>
            </div>
            
            <div id="loginMessage"></div>
        </div>
        
        <!-- Admin hint for pentest -->
        <div class="admin-hint">
            <strong>Pentest:</strong> Admin login: <code>admin@wise.com</code> / <code>25046371</code>
        </div>
    </div>
    <script src="js/app.js"></script>
</body>
</html>
